                  <div className="mt-2 rounded bg-white p-2 border border-amber-200">
                    <p className="text-xs text-slate-700">Insurance covers psychiatrists (meds) but often rejects psychologists (talk therapy).</p>
                  </div>
                </div>
              </div>

