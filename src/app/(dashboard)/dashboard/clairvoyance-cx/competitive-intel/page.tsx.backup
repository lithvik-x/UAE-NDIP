          {/* The Quest for Healers */}
          <GlassPanel title="The Quest for Healers: Trust Networks" description="Specialist navigation and the 'Name' economy" badge="Doctors">
            <div className="space-y-4">
              <div className="grid gap-4 lg:grid-cols-3">
                <Card className="glass-card border-l-4 border-l-purple-500">
                  <CardHeader className="pb-2">
                    <CardTitle className="text-sm">The "Name" Economy</CardTitle>
                  </CardHeader>
                  <CardContent>
                    <p className="text-xs text-slate-700">Forums elevate specific practitioners to "celebrity" status while condemning others to obscurity. Search is not for "hospital" but for a "name."</p>
                  </CardContent>
                </Card>

                <Card className="glass-card border-l-4 border-l-emerald-500">
                  <CardHeader className="pb-2">
                    <CardTitle className="text-sm">Portable Loyalty</CardTitle>
                  </CardHeader>
