                  <CardHeader className="pb-2">
                    <CardTitle className="text-sm">Primary Care Vacuum</CardTitle>
                  </CardHeader>
                  <CardContent>
                    <p className="text-xs text-slate-700">"No family doctor concept in Abu Dhabi" - fragmentation forces patient to become own care coordinator.</p>
                  </CardContent>
