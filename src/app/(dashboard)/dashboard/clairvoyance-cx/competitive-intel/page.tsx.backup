// Helper function for competitor badge colors
function getCompetitorBadgeColor(type: string): 'cyan' | 'emerald' | 'success' | 'denim' {
  const colorMap: Record<string, 'cyan' | 'emerald' | 'success' | 'denim'> = {
    'Service Hub': 'cyan',
    'Federal Voice': 'emerald',
    'Scale Model': 'success',
  }
  return colorMap[type] || 'denim'
}

// Helper function for influencer badge colors
function getInfluencerBadgeColor(color: string): 'purple' | 'denim' | 'rose' | 'gold' | 'cyan' | 'orange' {
  const colorMap: Record<string, 'purple' | 'denim' | 'rose' | 'gold' | 'cyan' | 'orange'> = {
    'purple': 'purple',
    'blue': 'denim',
    'rose': 'rose',
    'amber': 'gold',
    'cyan': 'cyan',
  }
  return colorMap[color] || 'denim'
}

