                        Insurance, Bureaucracy &amp; Expat Survival (10 voices)
                      </h6>
                      <ScrollArea className="h-[200px]">
                        <table className="w-full text-xs">
                          <thead className="sticky top-0 bg-slate-50 border-b border-slate-200">
                            <tr>
                              <th className="text-left p-2 font-semibold text-slate-900 w-12">#</th>
                              <th className="text-left p-2 font-semibold text-slate-900">Source Title</th>
                              <th className="text-left p-2 font-semibold text-slate-900">Key Takeaway</th>
                            </tr>
                          </thead>
                          <tbody>
                            {insuranceVoices.map((voice, idx) => (
                              <tr key={idx} className="border-b border-slate-100 hover:bg-white">
