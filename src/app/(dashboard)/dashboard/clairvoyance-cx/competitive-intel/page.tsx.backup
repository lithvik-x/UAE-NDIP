                    <div className="flex items-center gap-1 text-xs">
                      <Star className="h-3 w-3 text-purple-500" />
                      <span className="font-semibold">Sentiment:</span>
                      <span>"After care by pediatrics second to none"</span>
                    </div>
                    <div className="rounded bg-purple-50 p-2 border border-purple-200">
                      <p className="text-lg font-bold text-purple-700">~25,000 AED</p>
                    </div>
                  </CardContent>
                </Card>

                {/* Burjeel - Mid-Tier Struggle */}
                <Card className="glass-card border-t-4 border-t-amber-500">
